{
  "traditional": [
    {
      "id": 1,
      "dimension": "EI",
      "direction": "E",
      "text": "遇到新环境时，我通常会主动寻找可以交流的人。"
    },
    {
      "id": 2,
      "dimension": "EI",
      "direction": "I",
      "text": "经历密集社交后，我需要独处一段时间才能恢复状态。"
    },
    {
      "id": 3,
      "dimension": "EI",
      "direction": "E",
      "text": "我更容易在对话中边说边整理自己的想法。"
    },
    {
      "id": 4,
      "dimension": "EI",
      "direction": "I",
      "text": "重要想法在说出口前，我通常已经在心里反复推演过。"
    },
    {
      "id": 5,
      "dimension": "EI",
      "direction": "E",
      "text": "当团队气氛冷下来时，我会自然地想要把它带动起来。"
    },
    {
      "id": 6,
      "dimension": "EI",
      "direction": "I",
      "text": "比起参加大型聚会，我更偏好少数几个人的深入交流。"
    },
    {
      "id": 7,
      "dimension": "EI",
      "direction": "E",
      "text": "被很多人关注时，我通常会感到兴奋而不是消耗。"
    },
    {
      "id": 8,
      "dimension": "EI",
      "direction": "I",
      "text": "我更愿意用文字或安静的方式表达复杂想法。"
    },
    {
      "id": 9,
      "dimension": "EI",
      "direction": "E",
      "text": "我从与人互动中获得灵感和行动力。"
    },
    {
      "id": 10,
      "dimension": "EI",
      "direction": "I",
      "text": "如果一天没有安静时间，我会明显感到不舒服。"
    },
    {
      "id": 11,
      "dimension": "SN",
      "direction": "S",
      "text": "我更相信已经发生过的经验，而不是未经验证的可能性。"
    },
    {
      "id": 12,
      "dimension": "SN",
      "direction": "N",
      "text": "我经常会从一件小事联想到更大的模式或未来趋势。"
    },
    {
      "id": 13,
      "dimension": "SN",
      "direction": "S",
      "text": "解决问题时，我会先确认事实、流程和具体限制。"
    },
    {
      "id": 14,
      "dimension": "SN",
      "direction": "N",
      "text": "比起执行既定步骤，我更享受探索新的解释和可能性。"
    },
    {
      "id": 15,
      "dimension": "SN",
      "direction": "S",
      "text": "我容易注意到别人忽略的细节、数字或实际条件。"
    },
    {
      "id": 16,
      "dimension": "SN",
      "direction": "N",
      "text": "我常常被抽象概念、隐喻或长远愿景吸引。"
    },
    {
      "id": 17,
      "dimension": "SN",
      "direction": "S",
      "text": "如果一个想法无法落地，我会很快对它失去兴趣。"
    },
    {
      "id": 18,
      "dimension": "SN",
      "direction": "N",
      "text": "即使证据还不完整，我也会根据直觉形成初步判断。"
    },
    {
      "id": 19,
      "dimension": "SN",
      "direction": "S",
      "text": "我喜欢清楚、具体、可执行的说明。"
    },
    {
      "id": 20,
      "dimension": "SN",
      "direction": "N",
      "text": "我常常思考“如果事情换一种方式会怎样”。"
    },
    {
      "id": 21,
      "dimension": "TF",
      "direction": "T",
      "text": "做决定时，我会优先考虑逻辑一致性和客观标准。"
    },
    {
      "id": 22,
      "dimension": "TF",
      "direction": "F",
      "text": "做决定时，我会认真考虑它对相关人的情绪和关系影响。"
    },
    {
      "id": 23,
      "dimension": "TF",
      "direction": "T",
      "text": "指出问题时，我认为准确比委婉更重要。"
    },
    {
      "id": 24,
      "dimension": "TF",
      "direction": "F",
      "text": "如果真话会造成伤害，我会先考虑怎样表达才不破坏关系。"
    },
    {
      "id": 25,
      "dimension": "TF",
      "direction": "T",
      "text": "争论中我更关注观点是否成立，而不是气氛是否融洽。"
    },
    {
      "id": 26,
      "dimension": "TF",
      "direction": "F",
      "text": "别人情绪变化会明显影响我的判断和行动方式。"
    },
    {
      "id": 27,
      "dimension": "TF",
      "direction": "T",
      "text": "我欣赏能直接面对问题、哪怕听起来有些尖锐的人。"
    },
    {
      "id": 28,
      "dimension": "TF",
      "direction": "F",
      "text": "我会为了维护团队和谐而调整自己的表达或决定。"
    },
    {
      "id": 29,
      "dimension": "TF",
      "direction": "T",
      "text": "当规则和个人感受冲突时，我更倾向维护规则。"
    },
    {
      "id": 30,
      "dimension": "TF",
      "direction": "F",
      "text": "我更容易被“这个决定是否善待了人”说服。"
    },
    {
      "id": 31,
      "dimension": "JP",
      "direction": "J",
      "text": "事情开始前，我喜欢先确定目标、步骤和时间安排。"
    },
    {
      "id": 32,
      "dimension": "JP",
      "direction": "P",
      "text": "我更喜欢保留选择空间，而不是太早把计划定死。"
    },
    {
      "id": 33,
      "dimension": "JP",
      "direction": "J",
      "text": "待办事项完成前，我很难真正放松。"
    },
    {
      "id": 34,
      "dimension": "JP",
      "direction": "P",
      "text": "临近截止日期的压力有时反而能激发我的效率。"
    },
    {
      "id": 35,
      "dimension": "JP",
      "direction": "J",
      "text": "清晰的规则和稳定的节奏会让我更安心。"
    },
    {
      "id": 36,
      "dimension": "JP",
      "direction": "P",
      "text": "如果计划突然改变，我通常能很快调整状态。"
    },
    {
      "id": 37,
      "dimension": "JP",
      "direction": "J",
      "text": "我倾向于把生活和工作整理得井井有条。"
    },
    {
      "id": 38,
      "dimension": "JP",
      "direction": "P",
      "text": "我不喜欢被过细的日程限制住。"
    },
    {
      "id": 39,
      "dimension": "JP",
      "direction": "J",
      "text": "我会主动把模糊的事情推进到确定状态。"
    },
    {
      "id": 40,
      "dimension": "JP",
      "direction": "P",
      "text": "探索过程中出现的新机会常常比原计划更吸引我。"
    },
    {
      "id": 41,
      "dimension": "AT",
      "direction": "A",
      "text": "面对压力时，我通常相信自己能处理好局面。"
    },
    {
      "id": 42,
      "dimension": "AT",
      "direction": "T",
      "text": "即使事情已经完成，我也容易反复担心自己做得不够好。"
    },
    {
      "id": 43,
      "dimension": "AT",
      "direction": "A",
      "text": "外界评价通常不会轻易动摇我对自己的判断。"
    },
    {
      "id": 44,
      "dimension": "AT",
      "direction": "T",
      "text": "别人的一句否定可能会让我想很久。"
    },
    {
      "id": 45,
      "dimension": "AT",
      "direction": "A",
      "text": "遇到失败后，我通常能较快恢复行动。"
    },
    {
      "id": 46,
      "dimension": "AT",
      "direction": "T",
      "text": "在重要场合前，我经常担心自己会出错。"
    },
    {
      "id": 47,
      "dimension": "AT",
      "direction": "A",
      "text": "我对自己的选择通常比较笃定。"
    },
    {
      "id": 48,
      "dimension": "AT",
      "direction": "T",
      "text": "我会频繁比较自己和他人的表现。"
    },
    {
      "id": 49,
      "dimension": "AT",
      "direction": "A",
      "text": "即使结果不完美，我也能接受“已经足够好”。"
    },
    {
      "id": 50,
      "dimension": "AT",
      "direction": "T",
      "text": "我对未来的不确定性比较敏感，容易焦虑。"
    }
  ],
  "open_ended_pool": [
    {
      "id": "probe_EI_1",
      "text": "上一次你在社交中明明表现得很自然，但回家后突然觉得累，是因为什么？如果完全不用顾虑别人，你当时会怎么安排自己？",
      "hint": "写发生了什么、你当时的身体/情绪反应、最后你选择继续还是抽离。",
      "tags": [
        "probe_EI"
      ]
    },
    {
      "id": "probe_EI_2",
      "text": "想象你进入一个全是陌生人的房间，现场有一个你很感兴趣的话题。你会先观察、找熟人，还是直接加入？为什么？",
      "hint": "不要只写“看情况”，试着描述一个真实类似场景。",
      "tags": [
        "probe_EI"
      ]
    },
    {
      "id": "probe_SN_1",
      "text": "最近有没有一次你凭直觉觉得“不对劲”，但手上证据不足？你最后相信直觉还是继续找事实？结果如何？",
      "hint": "这题主要看你如何在事实和可能性之间切换。",
      "tags": [
        "probe_SN"
      ]
    },
    {
      "id": "probe_SN_2",
      "text": "如果一个方案听起来很有想象力，但细节暂时不完整；另一个方案很稳但没有新意，你会先支持哪一个？请举例。",
      "hint": "写你会问哪些问题，以及什么信息会改变你的选择。",
      "tags": [
        "probe_SN"
      ]
    },
    {
      "id": "probe_TF_1",
      "text": "上一次“说真话会伤人，不说又不诚实”的场景里，你最后怎么做？你更后悔伤害关系，还是更后悔没有说清楚？",
      "hint": "这类冲突比抽象自评更能看出决策方式。",
      "tags": [
        "probe_TF"
      ]
    },
    {
      "id": "probe_TF_2",
      "text": "团队里有人能力不够但态度很好，另一个人能力很强但总让大家不舒服。你更愿意和谁合作，为什么？",
      "hint": "写你会如何权衡结果、关系和公平。",
      "tags": [
        "probe_TF"
      ]
    },
    {
      "id": "probe_JP_1",
      "text": "如果你精心安排的一天被临时打乱，你第一反应通常是什么？你会立刻重排计划，还是顺势看看会发生什么？",
      "hint": "请描述一个真实例子，而不是理想中的自己。",
      "tags": [
        "probe_JP"
      ]
    },
    {
      "id": "probe_JP_2",
      "text": "有一件你一直拖着没开始的事，它卡住的真正原因是什么：缺计划、缺动力、怕承诺，还是还想等更好的机会？",
      "hint": "这题不是问自律，而是问你如何面对开放状态。",
      "tags": [
        "probe_JP"
      ]
    },
    {
      "id": "probe_AT_1",
      "text": "最近一次你因为别人评价而动摇，是哪句话？你当时如何解释这句话，后来又如何恢复？",
      "hint": "A/T 更关注压力下的自我信任和情绪波动。",
      "tags": [
        "probe_AT"
      ]
    },
    {
      "id": "probe_AT_2",
      "text": "当一件重要事情结果不理想时，你更容易想“下次调整就好”，还是“是不是我不够好”？请写一次具体经历。",
      "hint": "描述你脑子里最先冒出来的那句话。",
      "tags": [
        "probe_AT"
      ]
    },
    {
      "id": "depth_values_1",
      "text": "如果有人公开质疑你最看重的一项价值观，你会怎么回应？你会更想说服对方、理解对方，还是结束讨论？",
      "hint": "争议场景能看出你的能量、决策和压力反应。",
      "tags": [
        "mixed"
      ]
    },
    {
      "id": "depth_conflict_1",
      "text": "你有没有一次在关系中选择了沉默，但心里其实很不服？如果重来，你会继续沉默还是正面冲突？",
      "hint": "写你沉默/冲突背后的顾虑。",
      "tags": [
        "mixed"
      ]
    },
    {
      "id": "shadow_E_1",
      "text": "你最近一次感到真正孤独是什么时候？当时你在想什么、做了什么？",
      "hint": "就算你习惯与人相处，也总有安静下来的时刻吧",
      "tags": [
        "shadow_E"
      ]
    },
    {
      "id": "shadow_E_2",
      "text": "有没有哪次社交活动让你觉得'还不如不去'？是什么让你有了这种感觉？",
      "hint": "比如被迫营业、尬聊、或者结束后反而更累",
      "tags": [
        "shadow_E"
      ]
    },
    {
      "id": "shadow_I_1",
      "text": "如果有一天你变得完全不内向，可以和任何人轻松愉快地聊天。你觉得这样的你会是什么样子？",
      "hint": "你羡慕外向者的哪些方面？或者你觉得他们有什么烦恼是你没有的？",
      "tags": [
        "shadow_I"
      ]
    },
    {
      "id": "shadow_I_2",
      "text": "有没有哪次你很想说出自己的想法，但最终选择了沉默？如果再给你一次机会，你会说出来吗？",
      "hint": "是什么让你选择了沉默？怕冲突、觉得没必要、还是没来得及？",
      "tags": [
        "shadow_I"
      ]
    },
    {
      "id": "shadow_S_1",
      "text": "你有没有过那种'说不清为什么，但就是感觉不对'的经历？后来事实证明你的直觉对吗？",
      "hint": "哪怕没有任何依据的第六感",
      "tags": [
        "shadow_S"
      ]
    },
    {
      "id": "shadow_S_2",
      "text": "有人说'信任是一种选择，不是一种证据'。你怎么看待这句话？",
      "hint": "你更依赖证据还是信赖感？",
      "tags": [
        "shadow_S"
      ]
    },
    {
      "id": "shadow_N_1",
      "text": "你最近一次因为忽略实际细节而出问题是什么时候？比如看错时间、算错预算、忘了确认。",
      "hint": "小事也行，不一定非得是大事",
      "tags": [
        "shadow_N"
      ]
    },
    {
      "id": "shadow_N_2",
      "text": "如果让你完全活在自己理想的世界里，代价是不能和现实中的任何人交流，你愿意吗？为什么？",
      "hint": "理想世界可以有你想要的一切，只是你出不来",
      "tags": [
        "shadow_N"
      ]
    },
    {
      "id": "shadow_T_1",
      "text": "你做过最不理性但绝不后悔的决定是什么？",
      "hint": "那个你明知道不合理、但再来一次还是会做的事",
      "tags": [
        "shadow_T"
      ]
    },
    {
      "id": "shadow_T_2",
      "text": "你有没有因为'说话太直'而伤害过别人？你后来是怎么处理的？",
      "hint": "你觉得真诚比委婉重要吗？还是有时会反思？",
      "tags": [
        "shadow_T"
      ]
    },
    {
      "id": "shadow_F_1",
      "text": "你有没有为了照顾别人的感受而委屈过自己？重来一次你会怎么选？",
      "hint": "别人可能都不知道你做了让步的那种",
      "tags": [
        "shadow_F"
      ]
    },
    {
      "id": "shadow_F_2",
      "text": "如果必须在'说出真相但伤害Ta'和'说个善意的谎言让Ta开心'之间选，你更倾向于哪个？为什么？",
      "hint": "有没有例外情况？",
      "tags": [
        "shadow_F"
      ]
    },
    {
      "id": "shadow_J_1",
      "text": "上一次你对自己说'算了，不管了'是什么时候？当时发生了什么？",
      "hint": "放弃掌控的那一刻，是解脱还是不安？",
      "tags": [
        "shadow_J"
      ]
    },
    {
      "id": "shadow_J_2",
      "text": "如果明天开始你所有的计划全部作废，你必须随心所欲地生活一周。你第一件事想做什么？",
      "hint": "完全没人管你、也不用管任何事的一周",
      "tags": [
        "shadow_J"
      ]
    },
    {
      "id": "shadow_P_1",
      "text": "有没有一件你特别想做但一直没开始的事？你觉得缺的是什么？",
      "hint": "时间、勇气、资源、还是就差那一个开始的契机？",
      "tags": [
        "shadow_P"
      ]
    },
    {
      "id": "shadow_P_2",
      "text": "迄今为止你做得最久的坚持是什么？是什么让你撑了下来？",
      "hint": "不一定是什么了不起的事，坚持本身就很了不起",
      "tags": [
        "shadow_P"
      ]
    },
    {
      "id": "mixed_1",
      "text": "当你面临一个重大决定时，你会列出清单分析利弊，还是更多地听从内心的声音？请举一个具体的例子。",
      "hint": "有没有过你用了其中一种方式，但另一种才是更好的选择的情况？",
      "tags": [
        "mixed"
      ]
    },
    {
      "id": "mixed_2",
      "text": "在一个满是陌生人的场合，你通常是先观察再行动，还是先融入再调整？哪一种让你更自在？",
      "hint": "比如第一天到新公司、新班级、或者一个聚会",
      "tags": [
        "mixed"
      ]
    },
    {
      "id": "mixed_3",
      "text": "你有没有被人严重误解过？你觉得是对方理解错了，还是你没表达清楚？你在乎吗？",
      "hint": "有没有试图解释？还是觉得没必要？",
      "tags": [
        "mixed"
      ]
    },
    {
      "id": "mixed_4",
      "text": "想象一下，一年后的你因为今天做出的一个决定而生活发生了巨大变化。你希望那个决定是什么？",
      "hint": "什么事是你现在就有能力做、但一直在犹豫的？",
      "tags": [
        "mixed"
      ]
    }
  ],
